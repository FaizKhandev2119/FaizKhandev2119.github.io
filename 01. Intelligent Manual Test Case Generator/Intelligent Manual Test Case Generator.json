      "parameters": {
        "jsCode": "const url = $input.first().json['Emter the URL of the JIRA ticket'];\n\nif (!url) {\n  throw new Error(\"JIRA URL not found\");\n}\n\nconst match = url.toUpperCase().match(/([A-Z]+-\\d+)/);\n\nif (!match) {\n  throw new Error(\"Invalid JIRA URL\");\n}\n\nreturn [\n  {\n    json: {\n      issueKey: match[1]\n    }\n  }\n];"
      },
