    {
      "parameters": {
        "jsCode": "// Input: items (3 items from loop done branch)\n\nlet finalText = \"\";\n\nitems.forEach((item, index) => {\n  const text = item.json.candidates?.[0]?.content?.parts?.[0]?.text || \"\";\n\n  finalText += `\\n\\n====================\\n`;\n  finalText += `Image ${index + 1} Description:\\n`;\n  finalText += `====================\\n`;\n  finalText += text;\n});\n\nreturn [\n  {\n    json: {\n      mergedDescription: finalText\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3248,
        1552
      ],
      "name": "Merge Image descriptions",
      "id": "5d94b15b-7b7a-4ed0-aca1-5957ed9dfc89"
    },
    {
      "parameters": {
        "jsCode": "// JIRA description\nconst jiraDesc =  $('Jira Software1').first().json.fields.description || \"\";\n\n// Image descriptions (merged wala output)\nconst imageDesc =$input.first().json.mergedDescription  || \"\";\n\n// Final formatted description\nconst description = `\n========================\n📝 JIRA DESCRIPTION\n========================\n${jiraDesc}\n\n========================\n🖼️ IMAGE ANALYSIS\n========================\n${imageDesc}\n\n========================\n✅ FINAL SUMMARY\n========================\nThe above descriptions include both the original JIRA issue details and AI-generated analysis of attached images. Please review for complete context.\n`;\n\nreturn [\n  {\n    json: {\n      description\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3472,
        1552
      ],
      "name": "Merge JIRA description + Images description",
      "id": "a656e330-5631-4aa9-8a08-2b13afed4456"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.item;\nlet description = \"\";\n\n// Case 1: Image (Gemini / Vision output)\nif (item.json?.candidates?.[0]?.content?.parts?.[0]?.text) {\n  description = item.json.candidates[0].content.parts[0].text;\n}\n\n// Case 2: Manual Form Input\nelse if (item.json?.[\"Enter Description in the textbox below\"]) {\n  description = item.json[\"Enter Description in the textbox below\"];\n}\n\n// Case 3: OCR Output (markdown)\nelse if ($input.first()?.json?.pages?.[0]?.markdown) {\n  description = $input.first().json.pages[0].markdown;\n}\n\n// Case 4: Generic fallback\nelse if (item.json?.description) {\n  description = item.json.description;\n}\n\n// Case 5: Safety fallback\nelse {\n  throw new Error(\"No valid description found from input source\");\n}\n\nreturn [\n  {\n    json: {\n      Description: description.trim()\n    }\n  }\n];"
      },
