        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"Describe this UI in detail including all buttons, input fields, labels, layout and possible user actions.\"\n        },\n        {\n          \"inline_data\": {\n           \"mime_type\": \"image/jpeg\",\n            \"data\": \"{{ $json.image_base64 }}\"\n          }\n        }\n      ]\n    }\n  ]\n}",
