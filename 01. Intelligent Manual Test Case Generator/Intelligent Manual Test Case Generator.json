    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst results = await Promise.all(\n  items.map(async (item, index) => {\n\n    if (!item.binary) {\n      throw new Error(\"No binary data found\");\n    }\n\n    const binaryKey = Object.keys(item.binary)[0];\n\n    // Read actual file buffer from filesystem storage\n    const buffer = await this.helpers.getBinaryDataBuffer(\n      index,\n      binaryKey\n    );\n\n    return {\n      json: {\n        image_base64: buffer.toString('base64'),\n        mime_type: item.binary[binaryKey].mimeType,\n        file_name: item.binary[binaryKey].fileName\n      }\n    };\n  })\n);\n\nreturn results;"
      },
